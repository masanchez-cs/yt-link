# AL2023: el binario "yt-dlp" de GitHub usa el Python del sistema (suele ser 3.9); yt-dlp exige Python >= 3.10.
# Solución: python3.11 + pip + yt-dlp. No instalar el paquete RPM "curl" (choca con curl-minimal).
# ffmpeg: binario estático johnvansickle.

files:
  "/opt/elasticbeanstalk/bin/install-media-tools.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -euo pipefail
      dnf install -y tar xz

      if dnf install -y python3.11 python3.11-pip; then
        PY=python3.11
      elif dnf install -y python3.12 python3.12-pip; then
        PY=python3.12
      else
        echo "No se pudo instalar python3.11 ni python3.12 desde repos."
        exit 1
      fi

      "$PY" -m pip install --no-cache-dir yt-dlp || "$PY" -m pip install --no-cache-dir yt-dlp --break-system-packages

      if ! command -v yt-dlp >/dev/null 2>&1; then
        echo "yt-dlp no quedó en PATH tras pip."
        exit 1
      fi
      # pip como root suele dejar el ejecutable en /usr/local/bin/yt-dlp; no usar ln si ya es esa ruta (evita "same file").

      ARCH=$(uname -m)
      TMPD="$(mktemp -d)"
      trap 'rm -rf "$TMPD"' EXIT
      cd "$TMPD"
      if [ "$ARCH" = "x86_64" ]; then
        curl -fL https://johnvansickle.com/ffmpeg/releases/ffmpeg-release-amd64-static.tar.xz -o ff.tar.xz
      elif [ "$ARCH" = "aarch64" ]; then
        curl -fL https://johnvansickle.com/ffmpeg/releases/ffmpeg-release-arm64-static.tar.xz -o ff.tar.xz
      else
        echo "Arquitectura no soportada: $ARCH"
        exit 1
      fi
      tar -xf ff.tar.xz
      FF="$(find "$TMPD" -type f -name ffmpeg -print -quit)"
      if [ -z "$FF" ] || [ ! -x "$FF" ]; then
        echo "No se encontró ffmpeg dentro del tarball."
        exit 1
      fi
      cp "$FF" /usr/local/bin/ffmpeg
      chmod +x /usr/local/bin/ffmpeg

      command -v ffmpeg
      command -v yt-dlp
      ffmpeg -version | head -n 1
      /usr/local/bin/yt-dlp --version | head -n 1

commands:
  01_media_tools:
    command: /opt/elasticbeanstalk/bin/install-media-tools.sh
