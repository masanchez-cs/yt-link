# Instala ffmpeg y yt-dlp en instancias Amazon Linux 2023 (Elastic Beanstalk).
# Orden: paquetes del sistema → pip → comprobación.
# Si ffmpeg no está en los repos de tu región/AMI, revisa los logs del despliegue y añade un repo extra o binario estático.

packages:
  yum:
    python3-pip: []

commands:
  01_ffmpeg:
    command: dnf install -y ffmpeg
    ignoreErrors: true
  02_pip_tools:
    command: python3 -m pip install --upgrade pip setuptools wheel
  03_ytdlp:
    command: python3 -m pip install yt-dlp
  04_verify:
    command: |
      command -v yt-dlp
      yt-dlp --version | head -n 1
      if command -v ffmpeg >/dev/null 2>&1; then
        ffmpeg -version | head -n 1
      else
        echo "ADVERTENCIA: ffmpeg no está en PATH; el preset MP4 fusionado puede fallar. Opción: dnf install ffmpeg o FFMPEG_PATH en variables de entorno."
      fi
