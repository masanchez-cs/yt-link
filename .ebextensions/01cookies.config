# Materializa el archivo Netscape de cookies en la instancia EB leyendo una
# variable secreta de entorno (base64) para no guardar cookies en git.
#
# Requiere definir en EB:
#   YTLINK_YTDLP_COOKIES_B64=<contenido base64 de youtube-cookies.txt>
#
# El directorio /home/webapp/.ytlink se endurece en 03-ytlink-cookies-dir.config.
commands:
  02_write_youtube_cookies:
    command: |
      set -euo pipefail
      OUT="/home/webapp/.ytlink/youtube-cookies.txt"
      GETCFG="/opt/elasticbeanstalk/bin/get-config"

      if [ ! -x "$GETCFG" ]; then
        echo "No existe get-config en $GETCFG"
        exit 1
      fi

      COOKIES_B64="$($GETCFG environment -k YTLINK_YTDLP_COOKIES_B64 || true)"
      COOKIES_B64="$(echo "$COOKIES_B64" | tr -d '\r\n')"

      if [ -z "$COOKIES_B64" ]; then
        echo "Falta variable YTLINK_YTDLP_COOKIES_B64 en el entorno EB."
        exit 1
      fi

      echo "$COOKIES_B64" | base64 -d >"$OUT"
      chown webapp:webapp "$OUT"
      chmod 600 "$OUT"
      test -s "$OUT"
