# Materializa el archivo Netscape de cookies de YouTube en la instancia EB.
# El directorio /home/webapp/.ytlink se endurece en 03-ytlink-cookies-dir.config
# (webapp:webapp 0750). Este archivo queda root:root 0644 para que el proceso
# Node (usuario webapp) pueda leerlo como "other".
#
# ATENCION: estas cookies dan sesion activa a la cuenta Google usada para
# exportarlas. Solo embebidas aqui porque la cuenta es dedicada a ytLink y el
# repo es privado. Para rotar: exportar cookies nuevas desde el navegador y
# reemplazar este bloque. Para migrar a S3/Secrets Manager ver README.
files:
  "/home/webapp/.ytlink/youtube-cookies.txt":
    mode: "000644"
    owner: root
    group: root
    content: |
