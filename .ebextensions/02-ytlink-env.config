# Rutas explícitas: el proceso de Node en EB a veces no incluye /usr/local/bin en PATH,
# y el formato "mp4_best" necesita que yt-dlp encuentre ffmpeg al fusionar.
option_settings:
  aws:elasticbeanstalk:application:environment:
    YT_DLP_PATH: /usr/local/bin/yt-dlp
    FFMPEG_PATH: /usr/local/bin/ffmpeg
    # Sube tú el archivo Netscape a esta ruta (Session Manager / SCP). Ver .env.example.
    YTLINK_YTDLP_COOKIES_FILE: /home/webapp/.ytlink/youtube-cookies.txt
