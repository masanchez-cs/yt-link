# Carpeta persistente para youtube-cookies.txt (no la subas al repo; cópiala a la instancia a mano).
# El archivo no se crea aquí: solo el directorio y permisos para el usuario de la app Node (webapp).
commands:
  01_ytlink_cookies_dir:
    command: |
      set -euo pipefail
      install -d -m 0750 -o webapp -g webapp /home/webapp/.ytlink
