# Garantiza build del frontend en EB aunque los hooks de .platform no se ejecuten.
container_commands:
  01_build_client:
    command: |
      set -euo pipefail
      if [ ! -f client/package.json ]; then
        echo "No existe client/package.json; se omite build de frontend."
        exit 0
      fi
      NODE_ENV=development npm ci --include=dev --prefix client
      npm run build --prefix client
      test -f client/dist/index.html
      rm -rf client/node_modules
