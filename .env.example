PORT=3847
# Orígenes permitidos para CORS (coma sin espacios extra). Incluye la URL del front en prod.
# Ej.: CORS_ORIGIN=https://d1234567890.cloudfront.net,https://ytlink.tudominio.com
CORS_ORIGIN=http://localhost:5173
# Carpeta base donde se guardan descargas (debe ser una ruta absoluta en tu equipo)
YTLINK_DOWNLOAD_DIR=
# Ruta al ejecutable. En Windows suele funcionar dejarlo vacío (se busca con where).
# Si falla, pon la ruta completa al .exe, p. ej. tras pip:
#   C:\Users\TU_USUARIO\AppData\Local\Programs\Python\Python312\Scripts\yt-dlp.exe
# Sin winget: descarga el .exe oficial (un solo archivo) desde la última versión en
#   https://github.com/yt-dlp/yt-dlp/releases/latest
# Guárdalo donde quieras (ej. C:\Tools\yt-dlp.exe) y pon esa ruta aquí.
# Otras opciones si las tienes: pip install -U yt-dlp  |  winget install yt-dlp.yt-dlp
# Sin comillas alrededor de la ruta. Si dotenv te da problemas con \, usa /:
# YT_DLP_PATH=C:/Users/TU_USUARIO/Tools/yt-dlp.exe
YT_DLP_PATH=
# Elastic Beanstalk (AL2023), si hace falta: /usr/local/bin/yt-dlp
# Para “Máxima calidad en MP4”: ruta a ffmpeg.exe o a la carpeta que lo contiene.
# Sin FFmpeg, yt-dlp descarga video y audio por separado y no los une.
#   https://ffmpeg.org/download.html
# Ejemplo: FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=
# infoEB Linux (fusión MP4): /usr/local/bin/ffmpeg
# Cookies Netscape para YouTube (opcional; en AWS suele hacer falta contra "Sign in to confirm you're not a bot").
# Exporta desde el navegador siguiendo la wiki de yt-dlp; nunca subas ese archivo al repositorio.
# Ej. local: C:/Users/TU_USUARIO/AppData/Local/ytlink/youtube-cookies.txt
# Ej. EB: sube el archivo a la instancia (p. ej. /home/webapp/.ytlink/youtube-cookies.txt) y pon esa ruta aquí.
YTLINK_YTDLP_COOKIES_FILE=
LOG_LEVEL=